# PrintPadi – Environment variables template
# Copy this file to .env.local and fill in actual values

# API base URL (backend origin, NO /api suffix)
# e.g., http://localhost:5000 or https://api.printpadi.com
VITE_API_BASE_URL=http://localhost:5000

# Optional: Cloudinary cloud name (for IonImgoptimization)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Optional: Google OAuth client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# WhatsApp number used by "Chat on WhatsApp" buttons (digits only, with country code)
VITE_WHATSAPP_PHONE_NUMBER=2348000000000

