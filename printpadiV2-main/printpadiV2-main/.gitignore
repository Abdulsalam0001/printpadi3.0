# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Cursor local debug session logs (do not commit)
.cursor/debug*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# visual regression captures (generated)
/visual-regression/output/

# Local-only design mocks for explore/search/cart-summary pixel diffs (do not add new PNG mocks to git)
visual-regression/reference/explore-design.png
visual-regression/reference/search-design.png
visual-regression/reference/cart-summary-tab1.png
visual-regression/reference/cart-summary-tab2.png
visual-regression/reference/product-pdp-design.png
visual-regression/reference/source-china-design.png
visual-regression/reference/request-quote-design.png
