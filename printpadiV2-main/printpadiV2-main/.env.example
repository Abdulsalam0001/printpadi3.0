# Copy to `.env.local`. Never commit real secrets.

# Server-side API origin only (no trailing slash, no /api suffix). Paths in code add /api/...
# API origin only (no /api suffix). Match printpadi-be PORT (often 3001 or 8000).
# Next storefront typically runs on 3000: npm run dev -- -p 3000
BASE_API_URL=http://localhost:8000

# Browser-visible API origin — same rules as BASE_API_URL (origin only).
NEXT_PUBLIC_BASE_API_URL=http://localhost:8000

# --- Cloudinary (customer design uploads) ---
# Cloud name for the Cloudinary account (also used by components/image-loader.tsx).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dpflpiqbz
# Unsigned upload preset configured in the Cloudinary dashboard.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
